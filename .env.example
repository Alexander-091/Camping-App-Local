# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Google Places API key (used by enrich_private.py)
# Get one at: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=your_key_here

# Secret token required to trigger the scraper via POST /api/scrape.
# Set to any long random string. Leave blank to disable auth (local dev only).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SCRAPE_SECRET=your_secret_here

# Path to the directory containing sepaq.db, photos.db, private.db.
# On Railway, set this to the mount path of your persistent volume (e.g. /data).
# Defaults to ../data relative to app.py (local dev default).
DATA_DIR=/data

# Path to the scraper directory containing scraper.py.
# On Railway, set to /app/scraper (adjust if your repo layout differs).
# Defaults to ../scraper relative to app.py (local dev default).
SCRAPER_DIR=/app/scraper
